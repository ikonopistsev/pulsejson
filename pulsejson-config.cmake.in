@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Ensure RapidJSON::RapidJSON is available before the targets file is loaded.
# RapidJSON installs vary widely:
#   - Modern: creates RapidJSON::RapidJSON directly
#   - Some: creates unnamespaced RapidJSON target
#   - Old (e.g. Gentoo 1.1.0): only sets RAPIDJSON_INCLUDE_DIRS variable
#   - None: fall back to find_path
if (NOT TARGET RapidJSON::RapidJSON)
    find_package(RapidJSON QUIET)

    if (TARGET RapidJSON::RapidJSON)
        # modern config — already done
    elseif (TARGET RapidJSON)
        add_library(RapidJSON::RapidJSON INTERFACE IMPORTED)
        target_link_libraries(RapidJSON::RapidJSON INTERFACE RapidJSON)
    elseif (RAPIDJSON_INCLUDE_DIRS OR RAPIDJSON_INCLUDE_DIR)
        # old-style config that only sets variables
        add_library(RapidJSON::RapidJSON INTERFACE IMPORTED)
        set_target_properties(RapidJSON::RapidJSON PROPERTIES
            INTERFACE_INCLUDE_DIRECTORIES
                "${RAPIDJSON_INCLUDE_DIRS}${RAPIDJSON_INCLUDE_DIR}")
    else()
        find_path(_pulsejson_rj_inc rapidjson/document.h)
        if (_pulsejson_rj_inc)
            add_library(RapidJSON::RapidJSON INTERFACE IMPORTED)
            set_target_properties(RapidJSON::RapidJSON PROPERTIES
                INTERFACE_INCLUDE_DIRECTORIES "${_pulsejson_rj_inc}")
            unset(_pulsejson_rj_inc)
        else()
            message(FATAL_ERROR
                "pulsejson requires RapidJSON headers. "
                "Install rapidjson-dev or set CMAKE_PREFIX_PATH.")
        endif()
    endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/pulsejson-targets.cmake")

set(pulsejson_pulsejson_FOUND TRUE)
check_required_components(pulsejson)
